#include <stdio.h>   // For input/output functions like printf and scanf
#include <stdlib.h>  // For malloc, calloc, free

int main() {
    int n, i;
    int *arr_malloc, *arr_calloc;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    // Using malloc
    arr_malloc = (int *)malloc(n * sizeof(int));
    if (arr_malloc == NULL) {
        printf("Memory allocation failed for malloc.\n");
        return 1;
    }

    // Initialize elements
    for (i = 0; i < n; i++) {
        arr_malloc[i] = i + 1;
    }

    printf("\nArray elements using malloc:\n");
    for (i = 0; i < n; i++) {
        printf("%d ", arr_malloc[i]);
    }

    // Using calloc
    arr_calloc = (int *)calloc(n, sizeof(int));
    if (arr_calloc == NULL) {
        printf("\nMemory allocation failed for calloc.\n");
        free(arr_malloc);
        return 1;
    }

    printf("\n\nArray elements using calloc (initialized to 0):\n");
    for (i = 0; i < n; i++) {
        printf("%d ", arr_calloc[i]);
    }

    // Free dynamically allocated memory
    free(arr_malloc);
    free(arr_calloc);

    return 0;
}
